{
  "routes": [
    {
      "route": "/admin.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin-troubleshoot.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/js/*", "*.css", "*.js", "*.json", "*.ico", "*.png", "*.jpg", "*.jpeg", "*.gif", "*.svg", "*.xml", "*.txt", "*.html"]
  },
  "mimeTypes": {
    ".xml": "application/xml",
    ".txt": "text/plain"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "X-XSS-Protection": "1; mode=block"
  }
}
